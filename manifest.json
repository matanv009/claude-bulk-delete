{
  "manifest_version": 3,
  "name": "Claude Bulk Delete Chats",
  "version": "1.0.0",
  "description": "Bulk delete chats from Claude.ai history",
  "host_permissions": ["https://claude.ai/*"],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
